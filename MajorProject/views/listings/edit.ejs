<% layout("/layouts/boilerplate") %>
<body>
  <div class="row mt-3">
    <div class="col-6 offset-3">
      <h2 id="edit_route">Edit Your List</h2>
      <form
        action="/listings/<%= list._id %>?_method=PUT"
        method="POST"
        novalidate
        class="needs-validation"
        enctype="multipart/form-data"
      >
        <div class="mb-3">
          <label for="title" class="form-lebel">Title </label>
          <input
            type="text"
            id="title"
            name="title"
            class="form-control"
            value="<%= list.title %>"
            required
          />
          <div class="valid-feedback">looks good</div>
          <div class="invalid-feedback">Enter Valid Title</div>
        </div>
        <div class="mb-3">
          <label for="description" class="form-lebel">Description</label>
          <textarea
            class="form-control"
            type="text"
            id="description"
            name="description"
            placeholder="Enter Description"
            class="form-control"
            rows="7"
            required
          >
<%= list.description %>
          </textarea>
          <div class="valid-feedback">looks good</div>
          <div class="invalid-feedback">Enter Valid Description</div>
        </div>
        <div class="mb-3">
          <label for="">Current Image</label><br>
          <img src="<%= currImg %>" alt="list Image" class="card-img show-card-img"/>
        </div>
        <div class="mb-3">
          <label for="image" class="form-lebel">Image</label>
          <input type="file" id="image" name="image" class="form-control" />
        </div>

        <div class="row">
          <div class="mb-3 col-md-4">
            <label for="price" class="form-lebel">Price</label>
            <input
              type="number"
              name="price"
              id="price"
              class="form-control"
              value="<%= list.price %>"
              required
            />
            <div class="valid-feedback">looks good</div>
            <div class="invalid-feedback">Enter Valid Price</div>
          </div>
          <div class="mb-3 col-md-8">
            <label for="country" class="form-lebel">Country</label>
            <input
              type="text"
              id="country"
              name="country"
              class="form-control"
              value="<%= list.country %>"
              required
            />
            <div class="valid-feedback">looks good</div>
            <div class="invalid-feedback">Enter Valid Country</div>
          </div>
        </div>

        <div class="mb-3">
          <label for="location" class="form-lebel">Location</label>
          <input
            type="text"
            id="location"
            name="location"
            class="form-control"
            value="<%= list.location %>"
            required
          />
          <div class="valid-feedback">looks good</div>
          <div class="invalid-feedback">Enter Valid Location</div>
        </div>
        <button class="btn btn-dark edit_btn mb-4">Edit List</button>
      </form>
    </div>
  </div>
</body>
