<% layout("/layouts/boilerplate") %>
<body>
  <div class="row mt-3">
    <div class="col-6 offset-3">
      <h2>Create New List</h2>
      <form
        action="/listings"
        method="POST"
        id="new_form"
        novalidate
        class="needs-validation"
      >
        <div class="mb-3">
          <label for="title" class="form-lebel">Title</label>
          <input
            type="text"
            id="title"
            name="title"
            placeholder="Enter title"
            class="form-control"
            required
          />
          <div class="valid-feedback">looks good</div>
          <div class="invalid-feedback">Enter Valid Title</div>
        </div>
        <div class="mb-3">
          <label for="description" class="form-lebel">Description</label>
          <textarea
            type="text"
            id="description"
            name="description"
            placeholder="Enter Description"
            class="form-control"
            rows="7"
            required
          ></textarea>
          <div class="valid-feedback">looks good</div>
          <div class="invalid-feedback">Enter Valid Description</div>
        </div>
        <div class="mb-3">
          <label for="image" class="form-lebel">Image URL</label>
          <input
            type="text"
            id="image"
            name="image"
            placeholder="Enter Image URL"
            class="form-control"
          />
        </div>
        <div class="row">
          <div class="mb-3 col-md-4">
            <label for="price" class="form-lebel">Price</label>
            <input
              type="text"
              name="price"
              id="price"
              placeholder="Enter Price"
              class="form-control"
              required
            />
            <div class="valid-feedback">looks good</div>
            <div class="invalid-feedback">Enter Valid Price</div>
          </div>
          <div class="mb-3 col-md-8">
            <label for="country" class="form-lebel">Country</label>
            <input
              type="text"
              id="country"
              name="country"
              placeholder="India"
              class="form-control"
              required
            />
            <div class="valid-feedback">looks good</div>
            <div class="invalid-feedback">Enter Valid Country</div>
          </div>
        </div>

        <div class="mb-3">
          <label for="location" class="form-lebel">Location</label>
          <input
            type="text"
            id="location"
            name="location"
            placeholder="Enter Location"
            class="form-control"
            required
          />
          <div class="valid-feedback">looks good</div>
          <div class="invalid-feedback">Enter Valid Location</div>
        </div>
        <button class="btn btn-dark add_btn mb-4">Submit List</button>
      </form>
    </div>
  </div>
</body>
