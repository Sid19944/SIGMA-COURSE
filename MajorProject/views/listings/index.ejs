<% layout("/layouts/boilerplate") %>
<style>
  #filters {
    display: flex;
    flex-wrap: wrap;
    border-radius: 20px;
    padding: 0 5px;
    align-items: center;
  }
  .filter {
    color: black;
    text-align: center;
    margin: 1rem 1rem 0 0;

    opacity: 0.5;
    cursor: pointer;
  }
  .filter:hover {
    opacity: 1;
  }
  a {
    text-decoration: none;
  }
  .tax-switch {
    border: 1px solid black;
    border-radius: 2rem;
    height: 3.5rem;
    padding: 1rem;
  }
  .tax-info {
    display: none;
  }
</style>
<body>
  <div id="filters">
    <a href="/listings/category/mountain">
      <div class="filter">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountain</p>
      </div>
    </a>
    <a href="/listings/category/mountain_city">
      <div class="filter">
        <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>Mountain city</p>
      </div>
    </a>
    <a href="/listings/category/city">
      <div class="filter">
        <div><i class="fa-solid fa-city"></i></div>
        <p>city</p>
      </div>
    </a>
    <a href="/listings/category/beach">
      <div class="filter">
        <div><i class="fa-solid fa-umbrella-beach"></i></div>
        <p>Beach</p>
      </div>
    </a>
    <div class="tax-switch ms-auto">
      <div class="form-check-reverse form-switch">
        <input
          class="form-check-input"
          type="checkbox"
          role="switch"
          id="switchCheckDefault"
        />
        <label class="form-check-label" for="switchCheckDefault"
          >Display total after Tax
        </label>
      </div>
    </div>
  </div>

  <% if(allListings.length > 0) { %>
  <h1>All Listings</h1>
  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
    <% for(list of allListings) { %>

    <a href="/listings/<%= list._id %>">
      <div class="card lisitng-card">
        <img
          src="<%= list.image.url %>"
          class="card-img-top"
          alt="list_image"
          style="height: 20rem"
        />
        <div class="card-img-overlay"></div>
        <div class="card-body">
          <h6 class="card-title"><%= list.title %></h6>
          <p class="card-text">
            &#8377; <%= list.price.toLocaleString("en-In") %> /night
            <i class="tax-info">+18%GST</i>
          </p>
        </div>
      </div>
    </a>
    <% } %>
  </div>
  <% } %>
</body>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for (tax of taxInfo) {
      if (tax.style.display != "inline") {
        tax.style.display = "inline";
      } else {
        tax.style.display = "none";
      }
    }
  });
</script>
